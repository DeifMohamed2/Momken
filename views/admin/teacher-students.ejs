<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/bootstrap.rtl.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body>
  <div class="container-fluid">
    <div class="row">
      <%- include('./partials/sidebar', { currentPage: 'teachers' }) %>

      <!-- Main content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">طلاب المعلم: <%= teacher.name %></h1>
          <div class="btn-toolbar mb-2 mb-md-0">
            <div class="btn-group me-2">
              <a href="/admin/teachers" class="btn btn-sm btn-outline-secondary">العودة للمعلمين</a>
              <a href="/admin/teachers/<%= teacher._id %>/edit" class="btn btn-sm btn-outline-primary">تعديل المعلم</a>
            </div>
          </div>
        </div>

        <!-- Teacher info card -->
        <div class="card mb-4">
          <div class="card-body">
            <div class="row">
              <div class="col-md-2">
                <img src="<%= teacher.logoImage %>" alt="<%= teacher.name %>" class="img-fluid rounded" style="max-height: 100px;">
              </div>
              <div class="col-md-10">
                <h3><%= teacher.brandName %></h3>
                <p><%= teacher.description %></p>
                <div class="d-flex">
                  <div class="me-3">
                    <strong>البريد الإلكتروني:</strong> <%= teacher.email %>
                  </div>
                  <div class="me-3">
                    <strong>الهاتف:</strong> <%= teacher.phone %>
                  </div>
                  <div class="me-3">
                    <strong>الرابط:</strong> <a href="/<%= teacher.slug %>" target="_blank">/<%= teacher.slug %></a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats cards -->
        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="card text-white bg-primary">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h5 class="card-title">إجمالي الطلاب</h5>
                    <h2 class="display-4"><%= totalStudents %></h2>
                  </div>
                  <i class="bi bi-people display-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Students list -->
        <div class="card">
          <div class="card-header">
            قائمة الطلاب
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>اسم الطالب</th>
                    <th>كود الطالب</th>
                    <th>الصف</th>
                    <th>رقم الهاتف</th>
                    <th>هاتف ولي الأمر</th>
                    <th>الحالة</th>
                    <th>تاريخ التسجيل</th>
                  </tr>
                </thead>
                <tbody>
                  <% students.forEach((student, index) => { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td><%= student.Username %></td>
                      <td><%= student.Code %></td>
                      <td><%= student.Grade %></td>
                      <td><%= student.phone %></td>
                      <td><%= student.parentPhone %></td>
                      <td>
                        <% if (student.subscribe) { %>
                          <span class="badge bg-success">نشط</span>
                        <% } else { %>
                          <span class="badge bg-warning">في انتظار التفعيل</span>
                        <% } %>
                      </td>
                      <td><%= new Date(student.createdAt).toLocaleDateString() %></td>
                    </tr>
                  <% }); %>
                  <% if (students.length === 0) { %>
                    <tr>
                      <td colspan="8" class="text-center">لا يوجد طلاب مسجلين لهذا المعلم</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="/js/bootstrap.bundle.min.js"></script>
</body>

</html>
