    <link
      rel="icon"
      href="assetsLanding/img/logoMomke.png"
      type="image/webp"
    />
    <!-- Consolidate and defer CSS loading -->
    <link rel="stylesheet" href="assetsLanding/css/all.min.css" />
    <link rel="stylesheet" href="assetsLanding/css/header.css" />
    <link rel="stylesheet" href="assetsLanding/css/style.css" />
    <link rel="stylesheet" href="assetsLanding/css/main.css" />

