    <title><% if (typeof teacher !== 'undefined' && teacher) { %><%= teacher.name %> - <%= teacher.brandName %><% } else { %>Momken Academy<% } %></title>
  </head>
  <body<% if (typeof teacher !== 'undefined' && teacher) { %> class="teacher-themed"<% } %>>
    <!-- Start Header -->
    <header>
    <%- include("./partials/head.ejs") %>

    </header>
    <!-- Start Landing -->
    <div class="Landing-page">
      <div class="container">
        <div class="Landing-page_left">
          <% if (typeof teacher !== 'undefined' && teacher) { %>
            <img src="<%= teacher.coverImage %>" alt="<%= teacher.name %>" loading="lazy" />
          <% } else { %>
            <img src="assetsLanding/img/logoMomke.png" alt="" loading="lazy" />
          <% } %>
        </div>
        <div class="Landing-page_right">
      
              <h2>منصة <span class="largefont">ممكن</span></h2>
        
            <% if (typeof teacher !== 'undefined' && teacher) { %>
                  <h2><span class="largefont" style="font-size: 3rem;"><%= teacher.name %></span></h2>
          <% }  %>    
      
          <p class="enhanced-text">
            <% if (typeof teacher !== 'undefined' && teacher && teacher.description) { %>
              <%= teacher.description %>
            <% } else { %>
              منصة متكاملة بها كل ما يحتاجه الطالب ليتفوق
            <% } %>
          </p>
          <div class="line-between"></div>
          <div class="Landing-btns">
            <!-- <button class="Landing-btn-enroll">اطلب الكتاب من هنا</button> -->
            <!-- <div class="line-btween"></div> -->
            <% if (typeof isTeacherPage !== 'undefined' && isTeacherPage && typeof teacherSlug !== 'undefined') { %>
              <a href="/<%= teacherSlug %>/Register">
            <% } else { %>
              <a href="/Register">
            <% } %>
            <button class="Landing-btn-book">
              ابدأ رحلتك <span>الأن</span>
            </button>
            </a>
          </div>
        </div>
      </div>
    </div>
    <!-- End Landing -->

    <!-- Start main-->
    <main>
      <section class="Intro" id="information">
        <div class="Section-title">
          <div class="section-line">
            <% if (typeof teacher !== 'undefined' && teacher) { %>
              <h1>مع <span><%= teacher.name %></span></h1>
            <% } else { %>
              <h1>مع منصة <span>ممكن</span></h1>
            <% } %>
          </div>
        </div>
        <div class="container">
          <div class="card">
            <div class="card-box card-box1">
              <img
                src="assetsLanding/img/book-brain_tiny_image (1).webp"
                loading="lazy"
                alt=""
              />
              <div>
                <h1>لماذا تختار برنامجنا؟</h1>
                <p>
                  و انضم إلينا اليوم واكتشف المزايا التي ستغير تجربتك بشكل
                  إيجابي لماذا تختار برنامجنا؟ نحن نقدم لك أفضل تجربة ممكنة لدعم
                  احتياجاتك
                </p>
                <button onclick="openVideo()" class="card-box-btn">
                  <i class="fas fa-book"></i>
                  <span >تعلم المزيد</span>
                </button>
              </div>
            </div>
            <div class="card-box card-box2">
              <div></div>
              <i class="fa-regular fa-clock"></i>
              <h3>هـتشارك</h3>
              <p>مجموعات للمناقشة عشان تسأل وتشارك أفكارك مع زمايلك</p>
            </div>
            <div class="card-box card-box3">
              <i class="fa-regular fa-flag"></i>
              <h3>هـتنافس</h3>
              <p>نظام نقط على كل امتحان بتدخلو وهدايا للطلبة النشيطة</p>
            </div>
            <div class="card-box card-box4">
              <i class="fa-regular fa-pen-to-square"></i>
              <h3>هـنجهزك</h3>
              <p>مش محتاج تسأل هذاكر إيه النهاردة.. إحنا هنقول لك</p>
            </div>
            <div class="card-box card-box5">
              <i class="fa-regular fa-star"></i>
              <h3>هـتدرب</h3>
              <p>امتحانات إلكترونية تقدر تعيدها لحد ما تتقنها</p>
            </div>
          </div>
        </div>
      </section>
      <!-- Teacher Section -->
      <section>
        <div class="Section-title">
         
          <div class="section-line">
           
            <h1>إختار <span>الكورس</span></h1>
          </div>
        </div>
    
        <div class="container">
        

        </div>
      </section>

      <section class="about-teacher">
        <div class="Section-title">
          <div class="section-line">
            <% if (typeof teacher !== 'undefined' && teacher) { %>
              <h1>نبذة عن <span><%= teacher.name %></span></h1>
            <% } else { %>
              <h1>اتعرف <span>علينا</span></h1>
            <% } %>
          </div>
        </div>
        <div class="container">
          <div class="about-teacher-left">
            <% if (typeof teacher !== 'undefined' && teacher) { %>
              <img
                src="<%= teacher.logoImage %>"
                loading="lazy"
                alt="<%= teacher.name %>"
                class="teacher-about-logo"
              />
              <% if (teacher.social && teacher.social.facebook) { %>
              <div class="teacher-social">
                <a href="<%= teacher.social.facebook %>" target="_blank" class="social-icon"><i class="fab fa-facebook"></i></a>
              </div>
              <% } %>
            <% } else { %>
              <img
                src="assetsLanding/img/logoMomke.png"
                loading="lazy"
                alt="فريق منصة ممكن"
                class="platform-logo"
              />
            <% } %>
          </div>
          <div class="about-teacher-right">
            <% if (typeof teacher !== 'undefined' && teacher) { %>
              <h1><%= teacher.brandName %></h1>
              <p><%= teacher.description || 'انضم إلينا في رحلة تعليمية مميزة مع أفضل المعلمين المتخصصين.' %></p>
            <% } else { %>
              <h1>نحن فريق منصة ممكن التعليمية</h1>
              <p>
                هل تريد إتقان اللغة العربية بطريقة ممتعة وفعّالة؟ انضم إلينا في
                منصة ممكن التعليمية! نقدم لك تجربة تعليمية فريدة، حيث المعرفة
                تلتقي بالإبداع. مع فريق متميز من المعلمين المختصين، نساعدك على
                استيعاب قواعد اللغة العربية بسهولة، وتطوير مهاراتك في القراءة
                والكتابة والنطق.
              </p>
            <% } %>
          </div>
        </div>
      </section>

    </main>
    <!-- Footer Section -->
     <%- include("./partials/footer.ejs") %>
    <script src="assetsLanding/js/script.js" defer></script>
  </body>
</html>
